-- utility functions

function on_game_start()
	load_mcm_values()
	RegisterScriptCallback("on_option_change", load_mcm_values)
end

function load_mcm_values()
	change_text_colour = ui_mcm.get("better_upgrade_tooltips/change_text_colour") or false
	alpha = ui_mcm.get("better_upgrade_tooltips/alpha") or 255
	local red = ui_mcm.get("better_upgrade_tooltips/red") or 255
	local green = ui_mcm.get("better_upgrade_tooltips/green") or 255
	local blue = ui_mcm.get("better_upgrade_tooltips/blue") or 255
	override_colour = "%c" .. (string.format("[%s,%s,%s,%s]", alpha, red, green, blue))
	override_colour_ARGB = GetARGB(alpha, red, green, blue)
	
	change_text_colour_neg = ui_mcm.get("better_upgrade_tooltips/change_text_colour_neg") or false
	alpha_neg = ui_mcm.get("better_upgrade_tooltips/alpha_neg") or 255
	local red_neg = ui_mcm.get("better_upgrade_tooltips/red_neg") or 255
	local green_neg = ui_mcm.get("better_upgrade_tooltips/green_neg") or 255
	local blue_neg = ui_mcm.get("better_upgrade_tooltips/blue_neg") or 255
	override_colour_neg = "%c" .. (string.format("[%s,%s,%s,%s]", alpha_neg, red_neg, green_neg, blue_neg))
	override_colour_neg_ARGB = GetARGB(alpha_neg, red_neg, green_neg, blue_neg)
	
end

-- these next two are taken from utils_item but doesnt cache

local param_special = {
	["hit_power"]               = { typ= "string" , functor= item_vector_to_num },
	["control_inertion_factor"] = { typ= "string" , functor= item_float_to_num },
}

local read_from_ini = utils_data.read_from_ini

function get_param(section, id, param, typ, add)
	printf("get_param | section: %s - id: %s - param: %s - type: %s - add: %s - upgrades table passed: %s", section, id, param, typ, add)
	
	-- Validate
	if not (section and param) then
		callstack()
		printf("!ERROR utils_item.get_param | missing parameters")
		return
	end
	
	-- For ammo, use its own function
	if param == "ammo_class" then
		return get_ammo(section, id, false)
	end
	
	-- Read section
	local typ_t = typ 
	typ = param_special[param] and param_special[param].typ or typ
	
	local value = read_from_ini(ini_sys, section, param, typ, nil)
	if (value == nil) then
		--printf("!ERROR itms_manager.get_item_param | param (%s) doesn't exist for [%s]", param, section)
		return
	end
	if param_special[param] then
		value = param_special[param].functor(value,0)
	end
	printf("get_param | section: %s - id: %s - param: %s | value in section: %s", section, id, param, value)

	-- Read installed upgrades
	local installed_upgr = id and utils_item.get_upgrades_installed(nil, id) or parse_list( ini_sys, section, "installed_upgrades")
	for k,upgr in pairs(installed_upgr) do
		local upgrade_sect = ini_sys:r_string_ex(upgr, "section")
		local upgrade_value = utils_data.read_from_ini(ini_sys, upgrade_sect, param, typ, nil)
		if (upgrade_value ~= nil) then
			if param_special[param] then
				upgrade_value = param_special[param].functor(upgrade_value,value)
			end

			if add and (typ_t == "float") then
				value = value + upgrade_value
			else
				value = upgrade_value
			end
			printf("get_param | section: %s - id: %s - param: %s | found installed-upgrade [%s], adjusted value: %s", section, id, param, upgr, value)
		end
	end
	
	return value
end

function dispersion_change_to_accuracy_percent_change(change)
	change = tonumber(change)
	printf("change is %s", change)
	local final = -(200/3 * change)
	return final
end

function PDM_change_to_handling_percent_change(change)
	change = tonumber(change)
	printf("change is %s", change)
	local final = -(5/21 * change) * 100
	return final
end

function cond_shot_dec_to_relaibility_percent_change(change)
	change = tonumber(change)
	printf("change is %s", change)
	local final = -10000*change
	return final
end

local ini_eff = ini_file("plugins\\grok_bo_enhanced_recoil.ltx")
function zoom_cam_disp_to_recoil_change(change, sec, selected_obj_id_arg_)
	change = tonumber(change)
	printf("change is %s", change)
	-- turns out this stat is not created by a linear equation so i cant give a direct differentiation without involving the original stat

	-- made for gamma mostly
	--copied from momopate_weaponstats.script

	local zoom_cam_dispersion = 0
	local zoom_cam_dispersion_inc = 0
	local recoil_s = 0
	local recoil_s_cnt = 0
	local recoil_e = 0
	local disp_factor = 0
	local enhanced_cam_factor = 0
	local max_recoil_to_normalize = 0.036036
	

	
	local sec_p = ini_sys:r_string_ex(sec, "parent_section") or sec
	local tbl = {}
	
	if not ini_eff:section_exist(sec_p) then
		printf("!!! no effects exist for %s", sec_p)
		return 0 												-- Safeguard to prevent crashes!
	end
	
	-- Literally just copy-pasted from grok_bo_enhanced_recoil.script
	tbl.s = {}
	local s = ini_eff:r_string_ex(sec_p,"s")
	local _s = str_explode(s,",")
	for i=1,#_s do
		tbl.s[#tbl.s + 1] = tonumber(_s[i])
	end
	
	tbl.e = {}
	local e = ini_eff:r_string_ex(sec_p,"e")
	local _e = str_explode(e,",")
	for i=1,#_e do
		local __e = str_explode(_e[i],":")
		for j=1,#__e do
			if (tonumber(__e[j]) > 0) then 
				tbl.e[#tbl.e + 1] = tonumber(__e[j])
			end
		end
		--tbl.e[#tbl.e + 1] = __e
	end
	
	local zoom_cam_dispersion = get_param(sec, selected_obj_id_arg_, "zoom_cam_dispersion", "float", true) or 0 
	local zoom_cam_dispersion_inc = get_param(sec, selected_obj_id_arg_, "zoom_cam_dispersion_inc", "float", true) or 0
	
	local final_zoom_cam_dispersion = zoom_cam_dispersion + change

	for i = 1, #tbl.s do
		recoil_s = recoil_s + tonumber(tbl.s[i])
		recoil_s_cnt = recoil_s_cnt + 1
	end
	recoil_s = (recoil_s / recoil_s_cnt)

	local recoil_e = tonumber(tbl.e[2]) or 1
	
	local disp_factor = 1 / ( zoom_cam_dispersion )
	
	local final_disp_factor = 1 / ( final_zoom_cam_dispersion )
	
	local enhanced_cam_factor = 1 / ( recoil_s + recoil_s + recoil_s + recoil_e )

	printf("/// Recoil config: Disp = %s + %s / Cam = %s + %s", zoom_cam_dispersion, zoom_cam_dispersion_inc * 0.1, recoil_s, recoil_e)


	final_recoil = ( disp_factor * enhanced_cam_factor ) * 100
	if final_recoil < 1 then
		final_recoil = 1
	end
	
	final_recoil_post_upg = ( final_disp_factor * enhanced_cam_factor ) * 100
	if final_recoil_post_upg < 1 then
		final_recoil_post_upg = 1
	end
	
	--printf("final_recoil is %s, final_recoil_post_upg is %s, section is %s, ververver", final_recoil, final_recoil_post_upg, sec)
	-- return (final_recoil)

	return final_recoil_post_upg - final_recoil
end

