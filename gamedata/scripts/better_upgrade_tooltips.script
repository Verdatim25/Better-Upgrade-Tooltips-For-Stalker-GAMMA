inventory_upgrades.property_functor_a = function(param1, name)
	--printf("-property_functor_a(%s,%s)",param1,name)
	_g.printf("function inventory_upgrades.property_functor_a called")
	local prorerty_name = char_ini:r_string(name, "name")
	
	local t_prorerty_name = game.translate_string(prorerty_name)
	-- make all the colours white for consistency
	if string.find(t_prorerty_name, "%%c%[0,255,255,255%]") then
		-- t_prorerty_name = "%c[0,255,255,255]" .. t_prorerty_name
		t_prorerty_name = string.gsub(t_prorerty_name, "%%c%[0,255,255,255%]", "")
	end
	load_mcm_values()
	local section_table = parse_names(param1)
	local section_table_n = #section_table
	local section = section_table[1]
	
	printf("%s,%s,%s", prorerty_name, section, name)
	
	if not prop_name_to_param[name] then
		printf("returning original function because prorerty_name is %s", name)
		local text = original_inv_upgrades_property_functor_a(param1, name)
		if string.find(text, "%%c%[0,255,255,255%]") then
			-- t_prorerty_name = "%c[0,255,255,255]" .. t_prorerty_name
			text = string.gsub(text, "%%c%[0,255,255,255%]", "")
		end
		if change_text_colour then
			return override_colour .. text
		else
			return text
		end
	end
	
	if(section_table_n==0) then
		return ""
	end
	if	name=="prop_night_vision_1"		or
		name=="prop_night_vision_2"		or
		name=="prop_night_vision_3"		or
		name=="prop_sprint"				or
		name=="prop_scanner"			or
		name=="prop_dozimeter"			or
		name=="prop_psy_controller"		then
			if change_text_colour then
				return override_colour .. t_prorerty_name
			else
				return t_prorerty_name
			end
	end
	local value = 0
	local sum = 0
	for i = 1,section_table_n do
		-- if not(char_ini:line_exist(section_table[i], "value")) or not(char_ini:r_string(section_table[i], "value")) then
		if (not(char_ini:line_exist(section_table[i], "value")) or not(char_ini:r_string(section_table[i], "value"))) and not prop_name_to_param[name] then
			if change_text_colour then
				return override_colour .. t_prorerty_name
			else
				return t_prorerty_name
			end
		end

		local _i = 1
		local stat_change
		local final_functor_index
		while not stat_change do
			printf("_i is %s, prop_name_to_param[name].param_name[_i] is %s, stat_change is %s", _i, prop_name_to_param[name].param_name[_i], stat_change)
			if prop_name_to_param[name].param_name[_i] == "fire_wound_protection" then
				local bone_protection_section = char_ini:r_string_ex(section_table[i], "bones_koeff_protection_add")
				local stat_changes = ini_sys:r_string_ex(bone_protection_section, "bip01_spine") or "0,0"
				stat_change = str_explode(stat_changes, ",")[2]
				printf("%s, %s, %s", bone_protection_section, stat_changes, stat_change)
			else
				stat_change = char_ini:r_string_ex(section_table[i], prop_name_to_param[name].param_name[_i] or "")
			end
			final_functor_index = _i
			if not prop_name_to_param[name].param_name[_i] then
				printf("stat %s is not defined! returning to original function", name)
				local text = original_inv_upgrades_property_functor_a(param1, name)
				if string.find(text, "%%c%[0,255,255,255%]") then
					-- t_prorerty_name = "%c[0,255,255,255]" .. t_prorerty_name
					text = string.gsub(text, "%%c%[0,255,255,255%]", "")
				end
				if change_text_colour then
					return override_colour .. text
				else
					return text
				end
			end
			_i = _i + 1
		end
		stat_change = stat_change or "0"
		printf("selected_obj_section is %s", selected_obj_section)
		local selected_obj_id_arg = selected_obj_id
		local percent_change = better_upgrade_tooltips[prop_name_to_param[name].functor[final_functor_index]](stat_change, selected_obj_section or "wpn_pm", selected_obj_id_arg)
		value = percent_change
		
		--value = math.floor((10*value)+0.5) / 10
		
		value = math.ceil(10*value) / 10
		
		if(name~="prop_night_vision") then
			sum = sum + tonumber(value)
		else
			sum = tonumber(value)
		end
		
	end
	local is_positive = false
	if(sum<0) then
		value = sum
	else
		value = "+"..sum
		is_positive = true
	end
	

	good = ((is_positive) and (not is_special_param(name)) or ((not is_positive) and (is_special_param(name))))
	
	if change_text_colour then
		if change_text_colour_neg then
			if good then
				t_prorerty_name = override_colour .. t_prorerty_name
			else
				t_prorerty_name = override_colour_neg .. t_prorerty_name
			end
		else
			t_prorerty_name = override_colour .. t_prorerty_name
		end
	end
	
	if(name=="prop_ammo_size" or name=="prop_artefact") then
		return t_prorerty_name.." "..value
	--elseif(name=="prop_restore_bleeding" or name=="prop_restore_health" or name=="prop_power") then
	elseif(name=="prop_restore_health") then
		if(name=="prop_power") then
			value = "+"..tonumber(value)*2
		end
 --		local str = string.format("%s %4.1f", t_prorerty_name, value)
 --		return str
		return t_prorerty_name.." "..value
	-- elseif(name=="prop_tonnage" or name=="prop_weightoutfit" or name=="prop_weight") then
	elseif(name=="prop_tonnage" or name=="prop_weightoutfit") then
			local str = string.format("%s %5.2f %s", t_prorerty_name, value, game.translate_string("st_kg"))
			return str
	elseif(name=="prop_night_vision") then
		if(tonumber(value)==1) then
			return t_prorerty_name
		else
			return game.translate_string(prorerty_name.."_"..tonumber(value))
		end
	elseif(name=="prop_no_buck" or name=="prop_autofire") then

		return t_prorerty_name
	end
	if	name=="prop_reliability"	or
		--name=="prop_recoil"			or
		name=="prop_dispersion"		or
		--name=="prop_bullet_speed"	or
		name=="prop_chem"			or
		name=="prop_psy"			or
		name=="prop_radio"			or
		name=="prop_thermo"			or
		name=="prop_electro"		or
		name=="prop_damage"			or
		name=="prop_armor"			or
		--name=="prop_rpm"			or
		name=="prop_durability"		or
		name=="prop_inertion"		then
			value = value.."%"
	end
	if name == "prop_bullet_speed" then
		value = value .. " " .. game.translate_string("st_stat_speed")
	elseif name == "prop_rpm" then
		value = value .. " RPM"
	end
	
	printf("value is %s", value)
	
	if name == "prop_weight" then
		if tonumber(value) > 0 then
			value = tostring(value) .. " " .. game.translate_string("st_kg")
		else
			value = tostring(value) .. " " .. game.translate_string("st_kg")
		end
	end
	
	if name == "prop_restore_bleeding" then
		if tonumber(value) > 0 then
			value = tostring(value) .. " " .. game.translate_string("st_ml_min")
		else
			value = tostring(value) .. " " .. game.translate_string("st_ml_min")
		end
	end
	if name == "prop_power" then
		if tonumber(value) > 0 then
			value = tostring(value) .. " " .. game.translate_string("st_microg")
		else
			value = tostring(value) .. " " .. game.translate_string("st_microg")
		end
	end
	
	return t_prorerty_name.." "..value
end

local original_property_functor_b = inventory_upgrades.property_functor_b
inventory_upgrades.property_functor_b = function( param1, name )
	local original_return = original_property_functor_b( param1, name )
	--printf("-property_functor_b(%s,%s)",param1,name)
