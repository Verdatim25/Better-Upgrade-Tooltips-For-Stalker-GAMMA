	-- return (final_recoil)

	return math.abs(final_recoil_post_upg - final_recoil)
end

function rpm_to_rpm(change)
	change = tonumber(change)
	printf("change is %s", change)
	return change
end

function momo_bullet_speed_function(change, sec, obj_id)
	local obj = get_object_by_id(obj_id)
	if obj then
		local cobj = obj:cast_Weapon()
		if (not cobj) then 
			return 0 
		end
		local id = obj and obj:id()
		local bullet_speed = get_param(sec, obj and obj:id(), "bullet_speed", "float", true) + change
		local ammo_list = utils_item.get_ammo(obj:section(), id)
		if ammo_list[1] then
			local k_bullet_speed = ini_sys:r_float_ex(ammo_list[1], "k_bullet_speed") or 1
			bullet_speed = (bullet_speed ~= 0) and (k_bullet_speed*bullet_speed) or k_bullet_speed
			bullet_speed = bullet_speed * 0.70
		end
		return normalize(bullet_speed, 0, 1000)
	end
end

function bullet_speed_to_bullet_speed(change, sec, obj_id)
	-- change = tonumber(change)
	-- printf("change is %s", change)
	-- return change
	local original_speed = momo_bullet_speed_function(0, sec, obj_id) or 0
	
	local new_speed = momo_bullet_speed_function(change, sec, obj_id) or original_speed
	
	_g.printf("%s, %s", original_speed, new_speed)
	return 1000 * math.abs(new_speed - original_speed)
end

function weight_to_weight(change)
	return change
end

-- the two below are form grok_actor_damage_balancer

local math_ceil = function(num)
	return math.ceil(num * 10) / 10
end

function get_adb_constants(st)
	if st == hit.fire_wound or st == "FireWound" then
		hit_type = HitTypeID["FireWound"]
		immunity = "fire_wound_immunity"
		protection = "FireWound"
		booster_type_def = 15
		adjuster = 0.80
		arti_adjuster = adjuster
		limiter = 0.65
		cap_stat = "fire_wound_cap"
		defense = "fire_wound_protection"
	end

	if st == hit.wound or st == "Wound" then
		hit_type = HitTypeID["Wound"]
		immunity = "wound_immunity"
		protection = "Wound"
		booster_type_def = 16
		adjuster = 0.58 * 1.20
		arti_adjuster = 0.58 * 2
		limiter = 0.65
		cap_stat = "wound_cap"
		defense = "wound_protection"
	end

	if st == hit.strike or st == "Strike" then
		hit_type = HitTypeID["Strike"]
		immunity = "strike_immunity"
		protection = "Strike"
		booster_type_def = 14
		adjuster = 0.55
		arti_adjuster = adjuster * 1.3
		limiter = 0.65
		elemental = 1
		cap_stat = "strike_cap"
		defense = "strike_protection"
	end

	if st == hit.explosion or st == "Explosion" then
		hit_type = HitTypeID["Explosion"]
		immunity = "explosion_immunity"
		protection = "Explosion"
		booster_type_def = 13
		adjuster = 0.45
		arti_adjuster = 0.675
		limiter = 0.65
		elemental = 1
		cap_stat = "explosion_cap"
		defense = "explosion_protection"
	end

	if st == hit.burn or st == "Burn" then
		hit_type = HitTypeID["Burn"]
		immunity = "burn_immunity"
		protection = "Burn"
		booster_type_def = 8
		adjuster = 1.00
		arti_adjuster = adjuster * 2.0
		limiter = 0.65
		elemental = 1
		cap_stat = "burn_cap"
		defense = "burn_protection"
	end

	if st == hit.light_burn or st == "Burn" then
		hit_type = HitTypeID["LightBurn"]
		immunity = "burn_immunity"
		protection = "Burn"
		booster_type_def = 8
		adjuster = 1.00
		arti_adjuster = adjuster * 2.0
		limiter = 0.65
		elemental = 1
		cap_stat = "burn_cap"
		defense = "burn_protection"
	end

	if st == hit.shock or st == "Shock" then
		hit_type = HitTypeID["Shock"]
		immunity = "shock_immunity"
		protection = "Shock"
		booster_type_def = 9
		adjuster = 0.102
		arti_adjuster = adjuster * 26.5
		limiter = 0.65
		elemental = 1
		cap_stat = "shock_cap"
		defense = "shock_protection"
	end

	if st == hit.chemical_burn or st == "ChemicalBurn" then
		hit_type = HitTypeID["ChemicalBurn"]
		immunity = "chemical_burn_immunity"
		protection = "ChemicalBurn"
		booster_type_def = 7
		adjuster = 1.32
		arti_adjuster = adjuster
		limiter = 0.65
		elemental = 1
		cap_stat = "chemical_burn_cap"
		defense = "chemical_burn_protection"
	end

--	if st == hit.radiation or st == "Radiation" then
--		hit_type = HitTypeID["Radiation"]
--		immunity = "radiation_immunity"
--		protection = "Radiation"
--		booster_type_def = 10
--		adjuster = 0.80
--		limiter = 1.00
--	end

	if st == hit.telepatic or st == "Telepatic" then
		hit_type = HitTypeID["Telepatic"]
		immunity = "telepatic_immunity"
		protection = "telepatic"
		booster_type_def = 6
		adjuster = 1.70
		arti_adjuster = 1.50
		limiter = 0.65
		elemental = 1
		psy = 1
		cap_stat = "telepatic_cap"
		defense = "telepatic_protection"
	end
end

function get_outfit_value(obj, sec, name, def, add)
	local outfit = IsOutfit(obj)
	local helmet = IsHeadgear(obj)

	total_prot = 0
	headshot = 0
	elemental = 0
	psy = 0
	adjuster = 1.00

	get_adb_constants(name)

	-- Outfit protection
	local armor_protection = 0
	local armor_bone_value = 0

	if obj and outfit then
		local cond = obj:condition()
		local c_outfit = obj:cast_CustomOutfit()
		if (c_outfit) then
			if protection == "FireWound" then
				armor_protection = math_ceil((c_outfit:GetBoneArmor( BoneID["bip01_spine"] ) + add) * adjuster *100) or 0
			else
				armor_protection = math_ceil((c_outfit:GetDefHitTypeProtection( hit_type ) + add) * adjuster *100 * 1/cond) or 0
			end
			return armor_protection
		end
	end

	-- Helmet protection
	local helmet_protection = 0
	local helmet_bone_value = 0
    if obj and helmet then
		local cond = obj:condition()
		local c_helmet = obj:cast_Helmet()
		if (c_helmet) then
			if protection == "FireWound" then
				helmet_protection = math_ceil((c_helmet:GetBoneArmor( BoneID["bip01_head"] ) + add) * adjuster *100) or 0
			else
				helmet_protection = math_ceil((c_helmet:GetDefHitTypeProtection( hit_type ) + add) * adjuster *100 * 1/cond) or 0
			end
			return helmet_protection
		end
	end

	if sec then
		if protection == "FireWound" then
			section_protection = math_ceil((SYS_GetParam(0,sec,"hit_fraction_actor") + add) * adjuster *100) or 0
		else
			section_protection = math_ceil((SYS_GetParam(0,sec, defense) + add) * adjuster *100) or 0
		end

		return section_protection
	end
end

function outfit_protection_to_percent_change(change, section, obj_id, identifier)

	local obj = get_object_by_id(obj_id)
	if not obj then return end
	
	local old_protection = get_outfit_value(obj, section, identifier, nil, 0)
	
	local new_protection = get_outfit_value(obj, section, identifier, nil, change)
	printf("new is %s, old is %s", new_protection, old_protection)
	return math.abs(new_protection - old_protection)
end

function shock_protection_to_percent_change(change, section, obj_id)
	return outfit_protection_to_percent_change(change, section, obj_id, "Shock")
end

function burn_protection_to_percent_change(change, section, obj_id)
	return outfit_protection_to_percent_change(change, section, obj_id, hit.burn)
end

function chemical_burn_protection_to_percent_change(change, section, obj_id)
	return outfit_protection_to_percent_change(change, section, obj_id, "ChemicalBurn")
end

function telepatic_protection_to_percent_change(change, section, obj_id)
	return outfit_protection_to_percent_change(change, section, obj_id, "Telepatic")
end

function wound_protection_to_percent_change(change, section, obj_id)
	return outfit_protection_to_percent_change(change, section, obj_id, "Wound")
end

function bleeding_restore_speed_to_ml_per_s(change)
	return change * 150000
end

function health_restore_speed_to_artefact_heal_percent(change)
	return 10000 * change
end

function radiation_protection_to_percent_change(change, section, obj_id)
	local obj = get_object_by_id(obj_id)
	if not obj then return end
	
	local multiplier = (100/SYS_GetParam(2,"actor_condition","radio_zone_max_power")) / 1.82143
	
	local original_protection = utils_item.get_outfit_protection(obj, section, "Radiation") * multiplier
	
	local new_protection = (utils_item.get_outfit_protection(obj, section, "Radiation") + change) * multiplier

	return math.abs(new_protection - original_protection)
end

function fire_wound_protection_to_percent_change(change, section, obj_id)
	return outfit_protection_to_percent_change(change, section, obj_id, "FireWound")
end

function power_restore_speed_to_mircog(change)
	return change * 100000
end

function durability_upgrade_to_condition_loss(change)
	-- for gamma, each durability upgrade reduces condition loss by 10%
	return (-10)
end

function ammo_mag_size_to_ammo_mag_size(change)
	return change
end

