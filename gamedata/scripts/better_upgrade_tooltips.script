utils_ui.parse_list = function(ini, key, val, convert)
	local original_return_value = parse_list(ini, key, val, convert)
	
	if val ~= "property" then
		return original_return_value
	end

	local upgrade_section = ini:r_string_ex(key, "section")
	
	local original_return_table = table.concat(original_return_value, ",")
	_g.printf(" ver ver %s, %s", upgrade_section, original_return_table)
	
	for prop_name,v in pairs(prop_name_to_param) do
		local _i = 0
		local stat_change
		while not stat_change do
			_i = _i + 1
			--printf("%s, %s", _i, v.param_name[_i])
			if not v.param_name[_i] then
				break
			end
			local temp = ini:r_string_ex(upgrade_section, v.param_name[_i])
			if temp then
				if tonumber(temp) ~= 0 then
					stat_change = v.param_name[_i]
				end
			end
		end
		
		local extra_prop_name = param_to_prop_name[stat_change]
		if extra_prop_name then
			if not string.find(original_return_table, extra_prop_name) then
				original_return_table = original_return_table .. "," .. extra_prop_name
				--printf("insert extra element %s, final table is %s", extra_prop_name, original_return_table)
			else
				--printf("original_return_table %s already contains extra_prop_name %s", original_return_table, extra_prop_name)
			end
		else
			--printf("no extra prop name for %s", stat_change)
		end
	end
	
	-- move artefact slot increases to the end to avoide text overlap
	local starts, ends = string.find(original_return_table, "prop_artefact")
	if starts and ends then
		original_return_table = string.sub(original_return_table, ends + 2)
		original_return_table = original_return_table .. ",prop_artefact"
		printf("inserted prop_artefact at the end of original_return_table, final result is %s", original_return_table)
	end
	
	local final_return_value = str_explode(original_return_table, ",")
	--print_r(final_return_value)
	return final_return_value or original_return_value
end

local original_function_utils_ui_upgr_update = utils_ui.UIInfoUpgr.Update

function utils_ui.UIInfoUpgr.Update(self, upgr, prereq, installed)
	original_function_utils_ui_upgr_update(self, upgr, prereq, installed)
	if not self:Pass(upgr) then
		self:Show(false)
		return
	end

	local props = utils_ui.parse_list(ini_sys, upgr, "property")
	
	for i=(#props + 1), 9 do
		self.prop[i].ico:Show(false)
		self.prop[i].txt:Show(false)
	end
	
	self:Sync_H(self.prop_frame, self.frame, (self.prop_h * #props + 20) )
	
	for i,prop in ipairs(props) do
		if change_text_colour then
			if change_text_colour_neg then
				if good then
					self.prop[i].txt:SetTextColor(GetARGB(alpha,255,255,255))
				else
					self.prop[i].txt:SetTextColor(GetARGB(alpha_neg,255,255,255))
				end
			else
				self.prop[i].txt:SetTextColor(GetARGB(alpha,255,255,255))
			end
		end
			
	end
	
	return
end

local original_function_OnCCMouse1_workshop = ui_workshop.UIWorkshopUpgrade.On_CC_Mouse1

ui_workshop.UIWorkshopUpgrade.On_CC_Mouse1 = function(self, cont, idx)
	original_function_OnCCMouse1_workshop(self, cont, idx)
	local obj = self.CC:GetCell_Selected(true)
	if (not obj) then
		return
	end
	selected_obj_section = obj:section()
	selected_obj_id = obj:id()
end

local original_function_itm_details_reset = ui_itm_details.UIItemSheet.Reset

ui_itm_details.UIItemSheet.Reset = function(self, obj)
	original_function_itm_details_reset(self, obj)
	
	if obj then
		selected_obj_section = obj:section()
		selected_obj_id = obj:id()
	end
end

-- normally the max number of properties shown is 5, due to the multiple values that this script allows, i need to set the max number higher to catch some edge cases, like bizon caliber conversion

local original_UIInfoUpgr_init_controls = utils_ui.UIInfoUpgr.InitControls

local XMLP = CScriptXmlInit()
XMLP:ParseFile("utils.xml")

utils_ui.UIInfoUpgr.InitControls = function(self)
	original_UIInfoUpgr_init_controls(self)
	for i=6,9 do
		self.prop[i] = {}
		self.prop[i].ico = XMLP:InitStatic("upgrade_info:properties:icon", self.prop_frame)
		pos = self.prop[i].ico:GetWndPos()
		self.prop[i].ico:SetWndPos(vector2():set( pos.x , pos.y + (self.prop_h * i) ))

		self.prop[i].txt = XMLP:InitTextWnd("upgrade_info:properties:txt", self.prop_frame)
		pos = self.prop[i].txt:GetWndPos()
		self.prop[i].txt:SetWndPos(vector2():set( pos.x , pos.y + (self.prop_h * i) ))
	end
end